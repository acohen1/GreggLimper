# Discord / OpenAI credentials
DISCORD_API_TOKEN=your-bot-token-here
OPENAI_API_KEY=your-openai-key-here

# Model IDs
COT_MODEL_ID=gpt-4o
MSG_MODEL_ID=gpt-4o
IMG_MODEL_ID=dall-e-3

# Cache
CACHE_LENGTH=1000             # max messages per channel

# Comma-separated list of Discord text-channel IDs the bot has access to
CHANNEL_IDS=123456789012345678,234567890123456789

# Image processing settings
MAX_IMAGE_MB = 30   # max size of image to process in megabytes
